  "defense_recommendations": [
    {
      "text": "Deploy kernel integrity monitoring. Turla Snake operates at kernel level and evades standard EDR.",
      "source": "CISA AA23-129A",
      "url": "https://www.cisa.gov/news-events/cybersecurity-advisories/aa23-129a"
    },
    {
      "text": "Audit Exchange transport agents. Remove non-Microsoft agents. LightNeuron installs as transport agent.",
      "source": "ESET LightNeuron",
      "url": "https://www.welivesecurity.com/2019/05/07/turla-lightneuron-email-too-far/"
    },
    {
      "text": "Implement strict egress filtering. Allow only known protocols/destinations.",
      "source": "NIST SP 800-41",
      "url": "https://csrc.nist.gov/pubs/sp/800/41/r1/final"
    },
    {
      "text": "Review all mitigations in CISA AA23-129A for Snake malware detection and removal.",
