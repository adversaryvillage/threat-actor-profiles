  "detection": [
    {
      "title": "Snake Rootkit Detection",
      "content": "Monitor for unsigned kernel drivers via Sysmon Event ID 6 (Driver Loaded). Detect named pipe patterns used by Snake (e.g., \\\\.\\pipe\\isarpc*). Deploy kernel integrity monitoring tools. The FBI released the PERSEUS tool specifically designed to detect and neutralize Snake installations.",
      "url": "https://www.cisa.gov/news-events/cybersecurity-advisories/aa23-129a"
    },
    {
      "title": "LightNeuron Exchange Backdoor",
      "content": "Audit Exchange TransportAgent registry entries for unknown DLL assemblies. Monitor for emails being silently forwarded, modified, or blocked by transport rules not created by administrators. Check IIS logs for anomalous Exchange Web Services activity.",
      "url": "https://www.welivesecurity.com/2019/05/07/turla-lightneuron-email-too-far/"
    },
    {
      "title": "Infrastructure Hijacking Detection",
      "content": "Monitor for unexpected changes in DNS resolution for known C2 infrastructure of other threat actors. Turla has documented history of hijacking OilRig/APT34 C2 servers. Deploy DNS monitoring for infrastructure changes in threat intel feeds.",
      "url": "https://securelist.com/the-epic-turla-operation/65545/"
    }
  ],
