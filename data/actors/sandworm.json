  "defense_recommendations": [
    {
      "text": "Air-gap or segment IT from OT/ICS/SCADA. Use unidirectional gateways where data transfer is needed.",
      "source": "NIST SP 800-82 Rev 3",
      "url": "https://csrc.nist.gov/pubs/sp/800/82/r3/final"
    },
    {
      "text": "Deploy OT-specific monitoring (Dragos, Claroty, Nozomi) for ICS protocol anomaly detection.",
      "source": "CISA ICS-CERT",
      "url": "https://www.cisa.gov/topics/industrial-control-systems"
    },
    {
      "text": "Patch EternalBlue (MS17-010) and disable SMBv1. NotPetya used EternalBlue for propagation causing $10B+ damages.",
      "source": "Microsoft MS17-010",
      "url": "https://learn.microsoft.com/en-us/security-updates/securitybulletins/2017/ms17-010"
    },
    {
      "text": "Implement immutable offline backups. Test restoration quarterly. Sandworm deploys wipers to destroy recovery.",
      "source": "CISA Ransomware Guide",
      "url": "https://www.cisa.gov/stopransomware/ransomware-guide"
    },
    {
      "text": "Establish OT incident response with manual override procedures. Operators must run facilities without digital controls.",
      "source": "NERC CIP Standards",
      "url": "https://www.nerc.com/pa/Stand/Pages/CIPStandards.aspx"
    }
  ],
