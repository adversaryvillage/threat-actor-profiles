  "detection": [
    {
      "title": "DNS Tunneling via TXT Records",
      "content": "Monitor for high-volume DNS TXT record queries to single domains. Alert on DNS query subdomain lengths exceeding 50 characters. Deploy passive DNS monitoring to identify C2 domain registration patterns. Sigma rule: net_dns_susp_txt_exec_query.",
      "url": "https://github.com/SigmaHQ/sigma/blob/master/rules/network/dns/net_dns_susp_txt_exec_query.yml"
    },
    {
      "title": "Exchange Web Shell Detection",
      "content": "Monitor IIS/Exchange log files for unusual .aspx file creation in OWA directories. Detect w3wp.exe spawning cmd.exe or PowerShell. Implement file integrity monitoring on Exchange virtual directories.",
      "url": "https://www.microsoft.com/en-us/security/blog/2021/03/02/hafnium-targeting-exchange-servers/"
    },
    {
      "title": "VBA Macro Execution Chain",
      "content": "Enable ASR rules to block Office applications from creating child processes. Monitor for WINWORD.EXE or EXCEL.EXE spawning powershell.exe, wscript.exe, or mshta.exe. Sigma rule: proc_creation_win_office_spawn_exe_from_temp.",
      "url": "https://github.com/SigmaHQ/sigma/blob/master/rules/windows/process_creation/proc_creation_win_office_spawn_exe_from_temp.yml"
    }
  ],
