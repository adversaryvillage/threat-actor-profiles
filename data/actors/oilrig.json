  "defense_recommendations": [
    {
      "text": "Implement DNS RPZ and sinkholing. OilRig's entire C2 relies on DNS tunneling.",
      "source": "CIS Control 9",
      "url": "https://www.cisecurity.org/controls/email-and-web-browser-protections"
    },
    {
      "text": "Patch Exchange vulnerabilities (ProxyLogon, ProxyShell). Monitor OWA directories for web shells.",
      "source": "CISA AA21-062A",
      "url": "https://www.cisa.gov/news-events/cybersecurity-advisories/aa21-062a"
    },
    {
      "text": "Block Office macros via GPO and ASR. Implement Mark of the Web enforcement.",
      "source": "Microsoft ASR",
      "url": "https://learn.microsoft.com/en-us/microsoft-365/security/defender-endpoint/attack-surface-reduction-rules-reference"
    },
    {
      "text": "Implement SPF strict, DKIM, DMARC p=reject on all domains.",
