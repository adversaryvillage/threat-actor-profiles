  "detection": [
    {
      "title": "RMM Tool Abuse Detection",
      "content": "Maintain an inventory of approved RMM tools. Alert on installation of ScreenConnect, Atera, SimpleHelp, AnyDesk, or TeamViewer if not approved for that endpoint. Monitor for RMM agent communication to unexpected tenant IDs or account identifiers.",
      "url": "https://www.cisa.gov/news-events/cybersecurity-advisories/aa22-055a"
    },
    {
      "title": "LOLBIN Execution Monitoring",
      "content": "Monitor mshta.exe executing remote HTA files from URLs. Detect regsvr32.exe loading remote SCT files via /s /u /i:URL patterns. Alert on rundll32.exe with unusual command-line arguments. Enable Windows ASR rules for LOLBIN restriction.",
      "url": "https://github.com/SigmaHQ/sigma/blob/master/rules/windows/process_creation/proc_creation_win_mshta_javascript.yml"
    },
    {
      "title": "PowerShell Obfuscation Detection",
      "content": "Enable Script Block Logging (Event ID 4104). Detect Base64-encoded commands, string concatenation obfuscation (-join, [char] casting), and Invoke-Expression (IEX) with downloaded content. Monitor for AMSI bypass attempts.",
      "url": "https://github.com/SigmaHQ/sigma/blob/master/rules/windows/powershell/powershell_script/posh_ps_susp_download.yml"
    }
  ],
