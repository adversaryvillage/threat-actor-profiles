  "defense_recommendations": [
    {
      "text": "Block unauthorized RMM tools (ScreenConnect, Atera, SimpleHelp). MuddyWater uses legitimate RMM for persistence.",
      "source": "CISA AA22-055A",
      "url": "https://www.cisa.gov/news-events/cybersecurity-advisories/aa22-055a"
    },
    {
      "text": "Deploy ASR rules blocking LOLBIN abuse (mshta.exe, regsvr32.exe, rundll32.exe).",
      "source": "Microsoft ASR",
      "url": "https://learn.microsoft.com/en-us/microsoft-365/security/defender-endpoint/attack-surface-reduction-rules-reference"
    },
    {
      "text": "Enable PowerShell CLM and Script Block Logging. MuddyWater uses obfuscated PowerShell heavily.",
      "source": "NSA/CISA PowerShell Guide",
      "url": "https://media.defense.gov/2022/Jun/22/2003021689/-1/-1/0/CSI_KEEPING_POWERSHELL_SECURITY_MEASURES_TO_USE_AND_EMBRACE_20220622.PDF"
    },
    {
      "text": "Block macros from internet via MOTW enforcement.",
