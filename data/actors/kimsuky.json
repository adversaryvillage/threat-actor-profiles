  "defense_recommendations": [
    {
      "text": "Deploy FIDO2/WebAuthn phishing-resistant MFA. Kimsuky's primary vector is credential phishing via cloned portals.",
      "source": "CISA AA20-301A",
      "url": "https://www.cisa.gov/news-events/cybersecurity-advisories/aa20-301a"
    },
    {
      "text": "Manage browser extensions via GPO. Allow only approved extensions. Kimsuky deploys SHARPEXT to read Gmail silently.",
      "source": "Volexity SHARPEXT",
      "url": "https://www.volexity.com/blog/2022/07/28/sharptongue-deploys-clever-mail-stealing-browser-extension-sharpext/"
    },
    {
      "text": "Monitor email forwarding rules for unauthorized external forwarding. Kimsuky creates silent forwarding rules.",
